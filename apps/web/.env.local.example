# Copy to .env.local and fill in your keys.

# Required — your OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Optional — enables real YouTube study-video recommendations.
# Get one from Google Cloud Console → enable "YouTube Data API v3" → create an API key.
# Without it, Eliora falls back to YouTube search links (which always work).
YOUTUBE_API_KEY=

# Auth.js (NextAuth) — Google sign-in.
# AUTH_SECRET: any random string. Generate with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
# Google OAuth credentials (https://console.cloud.google.com → APIs & Services → Credentials
# → Create OAuth client ID → Web application). Add this Authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
